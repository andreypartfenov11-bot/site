body{
	font-family: Arial, Sant-Serif;
	font-size: 100%;
	background-color: #d46263;
}
ul{
	margin: 0;
	padding: 0;
}
ul li{
	list-style-type: none;
}
a{
	text-decoration: none;
}
header{
	padding: 50px 0;
	background-color: #ce8e4d;

h1, h2{
	color: #d4bf6c;
	text-align: center;
}
nav{
	background-color: #e1eeef;
	border-color: #557e9e;
	border-style: solid;
	min-height: 64px;
}
nav li{
	float: left;
	width: 100px;
}
nav a{
	display: block;
	color: #272d1a;
	line-height: 4em;
	font-weight: bold;
	text-align: center;
}
nav li a:hover{
	color: #0c0c00;
	background-color: gray;
}
p{
	font-size: 16px;
	line-height: 1.3;
	margin-top: 0.1em;
	margin-bottom: 0;
	color: #00000f;
}
footer{
	background-color: lightgray;
	color: gray;
	padding: 20px;
	margin-top: 30px;
}
.img-container li{
	display: inline-block;
	width: 32%;
	padding: 10px;
}
.img-container{
	text-align: center;
	margin-top: 20px;
	width: 100%;
}
.img-container img{
	width: 80%;
	display: inline-block;
	transition: .25%;
}
.img-container ul li{
	list-style-type: none;
}
.inline-img img{
	width: 250px;
	display: inline-block;
	border-radius: 15px;
	text-align: center;
	transform: scale(0.95);
	transition: .3s;
	max-width: 35%;
}
.inline-img img:hover{
	transform: scale(1);
}
